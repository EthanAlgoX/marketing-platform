{
  "name": "marketing-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @marketing-platform/web --filter @marketing-platform/api --filter @marketing-platform/worker dev",
    "dev:web": "pnpm --filter @marketing-platform/web dev",
    "dev:api": "pnpm --filter @marketing-platform/api dev",
    "dev:worker": "pnpm --filter @marketing-platform/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @marketing-platform/database prisma:generate",
    "db:migrate": "pnpm --filter @marketing-platform/database prisma:migrate",
    "smoke:xiaohongshu-provider": "node scripts/providers/xiaohongshu-provider-interface-smoke.mjs",
    "smoke:zhihu-provider": "node scripts/providers/zhihu-provider-interface-smoke.mjs",
    "smoke:wechat-provider": "node scripts/providers/wechat-official-provider-interface-smoke.mjs",
    "smoke:cli-template-instructions": "node scripts/providers/cli-template-instruction-smoke.mjs",
    "loop:publish-smoke": "node scripts/publish-loop-smoke.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
